<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>
    <link rel="stylesheet" href="/styles.css">
    <link rel="icon" type="image/png" href="/logo-r.png">
</head>

<body data-active-page="<%= activePage %>" data-active-tool="<%= activeToolSlug || '' %>">
    <!-- ── Sidebar ── -->
    <aside class="sidebar">
        <div class="sidebar-logo">
            <img src="/logo-r.png" alt="Logo">
        </div>
        <nav>
            <ul>
                <li>
                    <a href="/" class="<%= activePage === 'dashboard' ? 'active' : '' %>" title="Início">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                            <polyline points="9 22 9 12 15 12 15 22" />
                        </svg>
                        <span class="nav-label">Início</span>
                    </a>
                </li>
                <li>
                    <a href="/planejamento" class="<%= activePage === 'planejamento' ? 'active' : '' %>" title="Planejamento">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z" />
                            <polyline points="14 2 14 8 20 8" />
                            <line x1="16" y1="13" x2="8" y2="13" />
                            <line x1="16" y1="17" x2="8" y2="17" />
                            <line x1="10" y1="9" x2="8" y2="9" />
                        </svg>
                        <span class="nav-label">Planejamento</span>
                    </a>
                </li>
                <li>
                    <a href="/clientes" class="<%= activePage === 'clientes' ? 'active' : '' %>" title="Clientes">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                            <circle cx="9" cy="7" r="4" />
                            <line x1="19" y1="8" x2="19" y2="14" />
                            <line x1="22" y1="11" x2="16" y2="11" />
                        </svg>
                        <span class="nav-label">Clientes</span>
                    </a>
                </li>
                <li>
                    <a href="/ferramentas" class="<%= activePage === 'ferramentas' ? 'active' : '' %>" title="Ferramentas">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="3" width="6" height="6" rx="1" />
                            <rect x="15" y="3" width="6" height="6" rx="1" />
                            <rect x="3" y="15" width="6" height="6" rx="1" />
                            <path d="M16 16h5v5h-5z" />
                            <path d="M15 11h2" />
                            <path d="M7 11h2" />
                            <path d="M11 15v2" />
                            <path d="M11 7v2" />
                        </svg>
                        <span class="nav-label">Ferramentas</span>
                    </a>
                </li>
            </ul>
        </nav>
        <div class="sidebar-bottom">
            <a href="/logout" title="Sair">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                    <polyline points="16 17 21 12 16 7" />
                    <line x1="21" y1="12" x2="9" y2="12" />
                </svg>
                <span class="nav-label">Sair</span>
            </a>
        </div>
    </aside>

    <!-- ── Main Canvas ── -->
    <main class="main-canvas">
        <div class="central-card">

            <!-- Custom Header -->
            <header class="panel-topbar">
                <div class="topbar-model">
                    <svg viewBox="0 0 24 24">
                        <path d="M12 2L4.5 20.29L5.21 21L12 18L18.79 21L19.5 20.29L12 2Z" />
                    </svg>
                    Gemini 3.1 Flash Lite
                </div>
                <div class="topbar-actions">
                    <button class="btn-icon" title="Notificações"><svg width="16" height="16" viewBox="0 0 24 24"
                            fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                            <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                        </svg></button>
                    <button class="btn-pill btn-pill-dark" onclick="window.open('/logout')">Finalizar Sessão</button>
                </div>
            </header>

            <!-- ── TAB: DASHBOARD ── -->
            <section id="dashboard-tab" class="dashboard-container tab-pane <%= activePage === 'dashboard' ? 'active' : '' %>">
                <div class="gemini-star-wrap" style="margin-bottom: 32px; display: flex; justify-content: center;">
                    <!-- Symmetric Flat Gemini Sparkle -->
                    <svg viewBox="0 0 100 100" class="gemini-symbol">
                        <circle cx="50" cy="50" r="48" fill="white" />
                        <path d="M50 15 C50 15 54 46 85 50 C54 54 50 85 50 85 C50 85 46 54 15 50 C46 46 50 15 50 15Z"
                            fill="url(#geminiGradient)" />
                        <defs>
                            <linearGradient id="geminiGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" style="stop-color:#4285F4" />
                                <stop offset="100%" style="stop-color:#9B72CB" />
                            </linearGradient>
                        </defs>
                    </svg>
                </div>

                <div class="greeting-area">
                    <h1 id="greeting-main">Boa tarde, <%= user.displayName.split(' ')[0] %></h1>
                    <p>O que vamos <span class="highlight-purple">criar hoje?</span></p>
                </div>

                <div class="dashboard-ctas">
                    <a class="btn-hero btn-hero-primary" href="/planejamento">
                        Criar Planejamento
                    </a>
                    <a class="btn-hero btn-hero-secondary" href="/clientes">
                        👤 Cadastrar Cliente
                    </a>
                </div>

                <div class="trends-toolbar">
                    <div class="trends-toolbar-left">
                        <div class="trends-header">COMECE COM UM TEMA EM ALTA</div>
                        <div class="trends-search">
                            <input id="trend-search-input" type="text" placeholder="Pesquisar nas trends..." aria-label="Pesquisar nas trends">
                            <button id="trend-search-btn" class="btn-icon btn-trend-toolbar" title="Pesquisar entre as trends">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="11" cy="11" r="8" />
                                    <line x1="21" y1="21" x2="16.65" y2="16.65" />
                                </svg>
                            </button>
                            <span id="trend-search-status" class="trend-search-status"></span>
                        </div>
                    </div>
                    <button id="trend-refresh-btn" class="btn-pill btn-refresh-trends" type="button">Refresh</button>
                </div>
                <div class="trends-grid" id="trends-grid">
                    <!-- Cards will be injected here via JS -->
                    <div class="trend-card visible stagger-1">
                        <div class="title">Carregando tendências...</div>
                    </div>
                    <div class="trend-card visible stagger-2">
                        <div class="title">Carregando tendências...</div>
                    </div>
                    <div class="trend-card visible stagger-3">
                        <div class="title">Carregando tendências...</div>
                    </div>
                    <div class="trend-card visible stagger-4">
                        <div class="title">Carregando tendências...</div>
                    </div>
                    <div class="trend-card visible stagger-5">
                        <div class="title">Carregando tendências...</div>
                    </div>
                    <div class="trend-card visible stagger-6">
                        <div class="title">Carregando tendências...</div>
                    </div>
                    <div class="trend-card visible stagger-7">
                        <div class="title">Carregando tendências...</div>
                    </div>
                    <div class="trend-card visible stagger-8">
                        <div class="title">Carregando tendências...</div>
                    </div>
                    <div class="trend-card visible stagger-9">
                        <div class="title">Carregando tendências...</div>
                    </div>
                    <div class="trend-card visible stagger-10">
                        <div class="title">Carregando tendências...</div>
                    </div>
                    <div class="trend-card visible stagger-11">
                        <div class="title">Carregando tendências...</div>
                    </div>
                    <div class="trend-card visible stagger-12">
                        <div class="title">Carregando tendências...</div>
                    </div>
                </div>

                <div class="dashboard-feedback-cta-wrap">
                    <button id="open-product-feedback" class="dashboard-feedback-trigger" type="button">
                        Está gostando da ferramenta? Tem ideias de melhorias? Dê um feedback!
                    </button>

                    <div id="product-feedback-panel" class="product-feedback-panel hidden">
                        <p>Seu feedback vai direto para o e-mail de melhoria do produto.</p>
                        <textarea id="product-feedback-text"
                            placeholder="Conte o que está funcionando bem e o que pode melhorar..."></textarea>
                        <div class="product-feedback-actions">
                            <button id="product-feedback-cancel" class="product-feedback-btn" type="button">Cancelar</button>
                            <button id="product-feedback-send" class="product-feedback-btn primary"
                                type="button">Enviar feedback</button>
                            <span id="product-feedback-status" class="product-feedback-status"></span>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ── TAB: PLANEJAMENTO ── -->
            <section id="orchestration-tab" class="tab-pane <%= activePage === 'planejamento' ? 'active' : '' %>">
                <div class="form-card">
                    <h2 class="form-title">Agente de Conteúdos</h2>
                    <p class="form-subtitle">Crie conteúdos estratégicos baseados em evidência com o método Result.</p>

                    <div class="input-group">
                        <label class="input-label">Customer Success (CS)</label>
                        <select id="cs-select">
                            <option value="" disabled selected>Selecione seu atendimento...</option>
                            <option>Marcos (Experience)</option>
                            <option>Gabriele (Experience)</option>
                            <option>Isabela (Customer Success)</option>
                            <option>Laysa (Customer Success)</option>
                            <option>Luís (Customer Success)</option>
                            <option>Vivian (Customer Success)</option>
                            <option>Arieli (Liderança)</option>
                            <option>Suellen (Customer Success)</option>
                            <option>Carol (Customer Success)</option>
                            <option>Outro</option>
                        </select>
                    </div>

                    <div class="input-group">
                        <label class="input-label">Médico ou Clínica</label>
                        <select id="doctor-select" disabled>
                            <option>Buscando médicos autorizados...</option>
                        </select>
                    </div>

                    <div class="input-group">
                        <label class="input-label">Instruções para o Gemini</label>
                        <textarea id="prompt-input" rows="5"
                            placeholder="Ex: Crie um carrossel sobre biohacking focado em longevidade ativa..."></textarea>
                        <div id="selected-trend-context" class="selected-trend-context hidden">
                            <span class="selected-trend-label">Trend vinculada ao prompt</span>
                            <a id="selected-trend-link" href="#" target="_blank" rel="noopener noreferrer"></a>
                            <button id="selected-trend-clear" class="selected-trend-clear" type="button">Remover trend</button>
                        </div>
                    </div>

                    <button class="btn-hero btn-hero-primary" style="width:100%" id="btn-generate"
                        onclick="generateCopy()">✨ Gerar planejamento personalizado</button>
                    <div id="loader"
                        style="display:none; text-align:center; padding:20px; color:var(--primary); font-weight:600;">
                        Sincronizando Drive & Gemini...</div>

                    <!-- Result Zone -->
                    <div id="step-result" class="hidden" style="margin-top:40px;">
                        <div style="background:var(--bg-hover); padding:24px; border-radius:18px; line-height:1.7; white-space:pre-wrap; color:var(--text-main);"
                            id="generated-content"></div>
                        <div style="display:flex; gap:12px; margin-top:20px;">
                            <button id="btn-download" class="btn-pill btn-pill-dark"
                                onclick="downloadGeneratedDocx()">Download .docx</button>
                            <button id="btn-new-content" class="btn-pill" style="border:1px solid var(--border-soft)">
                                Novo conteúdo
                            </button>
                            <button id="btn-review" class="btn-pill" style="border:1px solid var(--border-soft)">
                                Revisar
                            </button>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ── TAB: CLIENTES ── -->
            <section id="admin-tab" class="tab-pane <%= activePage === 'clientes' ? 'active' : '' %>">
                <div class="form-card">
                    <h2 class="form-title">Onboarding de Cliente</h2>
                    <p class="form-subtitle">Configure novos médicos e crie a estrutura do Google Drive.</p>

                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;">
                        <div class="input-group">
                            <label class="input-label">Nome Completo</label>
                            <input type="text" id="ob-name" placeholder="Ex: Dr. Fulano de Tal">
                        </div>
                        <div class="input-group">
                            <label class="input-label">Especialidade Principal</label>
                            <input type="text" id="ob-specialty" placeholder="Ex: Cirurgia Plástica">
                        </div>
                    </div>

                    <div class="input-group">
                        <label class="input-label">Atendimento Responsável</label>
                        <select id="ob-cs">
                            <option>Marcos</option>
                            <option>Gabriele</option>
                            <option>Isabela</option>
                            <option>Laysa</option>
                            <option>Luís</option>
                            <option>Vivian</option>
                            <option>Arieli</option>
                            <option>Suellen</option>
                            <option>Carol</option>
                        </select>
                    </div>

                    <div class="input-group">
                        <label class="input-label">Minibriefing (Branding & Estilo)</label>
                        <textarea id="ob-briefing" rows="3" placeholder="Descreva a voz do cliente..."></textarea>
                    </div>

                    <div class="input-group">
                        <label class="input-label">Arquivos Base (.docx, .pdf)</label>
                        <div onclick="document.getElementById('file-upload').click()"
                            style="background:var(--bg-hover); border:2px dashed var(--border-soft); padding:30px; border-radius:18px; text-align:center; cursor:pointer;">
                            <span style="color:var(--text-secondary); font-size:0.9rem;">Arraste ou clique para anexar
                                documentos</span>
                            <input type="file" id="file-upload" hidden multiple accept=".docx,.pdf">
                        </div>
                        <ul id="file-list"
                            style="list-style:none; padding:10px 0; font-size:0.85rem; color:var(--text-muted);"></ul>
                    </div>

                    <button class="btn-hero btn-hero-primary" style="width:100%" id="ob-submit-btn"
                        onclick="submitOnboarding()">🚀 Criar Estrutura no Drive</button>
                    <% if (driveDatabaseUrl) { %>
                        <a class="btn-hero btn-hero-secondary admin-drive-link" href="<%= driveDatabaseUrl %>" target="_blank" rel="noopener noreferrer">
                            Acessar banco de dados do Drive
                        </a>
                    <% } else { %>
                        <button class="btn-hero btn-hero-secondary admin-drive-link" type="button" disabled title="Configure GOOGLE_DRIVE_PARENT_ID no .env para habilitar este atalho.">
                            Acessar banco de dados do Drive
                        </button>
                    <% } %>
                </div>
            </section>

            <!-- ── TAB: FERRAMENTAS ── -->
            <section id="tools-tab" class="tab-pane <%= activePage === 'ferramentas' ? 'active' : '' %>">
                <div class="tools-page">
                    <% if (!activeToolSlug) { %>
                        <div class="tools-header tools-header-directory">
                            <span class="tools-kicker">UTILITÁRIOS</span>
                            <h2>Ferramentas</h2>
                            <p>Abra cada utilitário em uma página própria para trabalhar com mais foco. Aqui ficam apenas os atalhos rápidos do hub.</p>
                        </div>

                        <div class="tools-directory-grid">
                            <% tools.forEach((tool) => { %>
                                <a href="/ferramentas/<%= tool.slug %>" class="tool-link-card">
                                    <div class="tool-card-icon <%= tool.slug === 'gerador-whatsapp' ? 'whatsapp-icon' : tool.slug === 'color-picker' ? 'color-picker-icon' : tool.slug === 'correcao-texto' ? 'text-correction-icon' : '' %>" aria-hidden="true">
                                        <% if (tool.slug === 'gerador-qr') { %>
                                            <svg viewBox="0 0 96 96" fill="none">
                                                <rect x="8" y="8" width="28" height="28" rx="4" fill="#111827" />
                                                <rect x="16" y="16" width="12" height="12" rx="2" fill="#FFFFFF" />
                                                <rect x="60" y="8" width="28" height="28" rx="4" fill="#111827" />
                                                <rect x="68" y="16" width="12" height="12" rx="2" fill="#FFFFFF" />
                                                <rect x="8" y="60" width="28" height="28" rx="4" fill="#111827" />
                                                <rect x="16" y="68" width="12" height="12" rx="2" fill="#FFFFFF" />
                                                <rect x="48" y="48" width="8" height="8" rx="2" fill="#A855F7" />
                                                <rect x="60" y="48" width="12" height="12" rx="3" fill="#111827" />
                                                <rect x="76" y="48" width="12" height="28" rx="3" fill="#A855F7" />
                                                <rect x="48" y="64" width="12" height="24" rx="3" fill="#111827" />
                                                <rect x="64" y="68" width="8" height="8" rx="2" fill="#FFFFFF" />
                                            </svg>
                                        <% } else if (tool.slug === 'gerador-whatsapp') { %>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                                                class="bi bi-whatsapp" viewBox="0 0 16 16">
                                                <path
                                                    d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232" />
                                            </svg>
                                        <% } else { %>
                                            <svg viewBox="0 0 96 96" fill="none">
                                                <% if (tool.slug === 'color-picker') { %>
                                                    <circle cx="30" cy="30" r="18" fill="#EF4444" />
                                                    <circle cx="66" cy="30" r="18" fill="#F59E0B" />
                                                    <circle cx="30" cy="66" r="18" fill="#10B981" />
                                                    <circle cx="66" cy="66" r="18" fill="#3B82F6" />
                                                    <circle cx="48" cy="48" r="10" fill="#FFFFFF" />
                                                <% } else { %>
                                                    <rect x="14" y="16" width="68" height="56" rx="16" fill="#EEF2FF" />
                                                    <path d="M28 34h40" stroke="#111827" stroke-width="6" stroke-linecap="round" />
                                                    <path d="M28 48h24" stroke="#6366F1" stroke-width="6" stroke-linecap="round" />
                                                    <path d="m56 51 8 8 14-18" stroke="#10B981" stroke-width="6" stroke-linecap="round" stroke-linejoin="round" />
                                                <% } %>
                                            </svg>
                                        <% } %>
                                    </div>
                                    <span><%= tool.name %></span>
                                </a>
                            <% }) %>
                        </div>
                    <% } else { %>
                        <div class="tool-detail-page">
                            <div class="tools-header tools-detail-header">
                                <span class="tools-kicker">FERRAMENTA SELECIONADA</span>
                                <h2><%= activeTool.name %></h2>
                                <p>Cada utilitário agora roda em uma página dedicada. Isso deixa a navegação mais limpa e dá mais destaque para a ferramenta que está em uso.</p>
                            </div>

                            <div class="tool-detail-topbar">
                                <a href="/ferramentas" class="tool-back-link">← Voltar para ferramentas</a>
                                <div class="tool-switcher">
                                    <% tools.forEach((tool) => { %>
                                        <a href="/ferramentas/<%= tool.slug %>" class="tool-switcher-link <%= activeToolSlug === tool.slug ? 'active' : '' %>">
                                            <%= tool.shortName %>
                                        </a>
                                    <% }) %>
                                </div>
                            </div>

                            <% if (activeToolSlug === 'gerador-qr') { %>
                                <article class="tool-card tool-focus-card qr-tool-card">
                                    <div class="tool-focus-hero">
                                        <div class="tool-card-icon" aria-hidden="true">
                                            <svg viewBox="0 0 96 96" fill="none">
                                                <rect x="8" y="8" width="28" height="28" rx="4" fill="#111827" />
                                                <rect x="16" y="16" width="12" height="12" rx="2" fill="#FFFFFF" />
                                                <rect x="60" y="8" width="28" height="28" rx="4" fill="#111827" />
                                                <rect x="68" y="16" width="12" height="12" rx="2" fill="#FFFFFF" />
                                                <rect x="8" y="60" width="28" height="28" rx="4" fill="#111827" />
                                                <rect x="16" y="68" width="12" height="12" rx="2" fill="#FFFFFF" />
                                                <rect x="48" y="48" width="8" height="8" rx="2" fill="#A855F7" />
                                                <rect x="60" y="48" width="12" height="12" rx="3" fill="#111827" />
                                                <rect x="76" y="48" width="12" height="28" rx="3" fill="#A855F7" />
                                                <rect x="48" y="64" width="12" height="24" rx="3" fill="#111827" />
                                                <rect x="64" y="68" width="8" height="8" rx="2" fill="#FFFFFF" />
                                            </svg>
                                        </div>

                                        <div class="tool-focus-copy">
                                            <h3>Gerador de QR Code</h3>
                                            <p>Digite um texto ou link, gere o QR instantaneamente e baixe em PNG ou SVG vetorial para usar em campanhas, materiais impressos e peças digitais.</p>
                                        </div>
                                    </div>

                                    <div class="tool-focus-form">
                                        <div class="input-group">
                                            <label class="input-label" for="qr-input">Texto ou link</label>
                                            <textarea id="qr-input" rows="4"
                                                placeholder="Ex: https://resultpubli.com.br ou qualquer texto que voce queira converter em QR Code."></textarea>
                                        </div>
                                    </div>

                                    <div class="tool-focus-actions">
                                        <button class="btn-pill btn-pill-dark qr-generate-btn" type="button"
                                            onclick="openQrGeneratorModal()">
                                            Gerar QR Code
                                        </button>
                                        <span class="tool-focus-hint">
                                            Abra o preview para baixar em PNG ou SVG.
                                        </span>
                                    </div>

                                    <div id="qr-inline-status" class="tool-inline-status" aria-live="polite"></div>
                                </article>
                            <% } %>

                            <% if (activeToolSlug === 'gerador-whatsapp') { %>
                                <article class="tool-card tool-focus-card whatsapp-tool-card">
                                    <div class="tool-focus-hero">
                                        <div class="tool-card-icon whatsapp-icon" aria-hidden="true">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                                                class="bi bi-whatsapp" viewBox="0 0 16 16">
                                                <path
                                                    d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232" />
                                            </svg>
                                        </div>

                                        <div class="tool-focus-copy">
                                            <h3>Gerador de link WhatsApp</h3>
                                            <p>Monte links prontos para atendimento, campanhas e bio. Informe o número, defina uma mensagem padrão e copie o formato ideal para cada contexto.</p>
                                        </div>
                                    </div>

                                    <div class="tool-focus-form tool-focus-form-split">
                                        <div class="input-group">
                                            <label class="input-label" for="whatsapp-number">Número</label>
                                            <input type="text" id="whatsapp-number"
                                                placeholder="Ex: 5511999998888 ou (11) 99999-8888">
                                        </div>

                                        <div class="input-group">
                                            <label class="input-label" for="whatsapp-message">Mensagem padrão</label>
                                            <textarea id="whatsapp-message" rows="4"
                                                placeholder="Ex: Ola! Vim pelo site e gostaria de falar com voces."></textarea>
                                        </div>
                                    </div>

                                    <div class="tool-focus-actions">
                                        <button class="btn-pill btn-pill-dark qr-generate-btn" type="button"
                                            onclick="generateWhatsAppLinks()">
                                            Gerar link WhatsApp
                                        </button>
                                        <span class="tool-focus-hint">
                                            Gere os formatos `wa.me` e `api.whatsapp.com`.
                                        </span>
                                    </div>

                                    <div id="whatsapp-inline-status" class="tool-inline-status" aria-live="polite"></div>

                                    <div id="whatsapp-result" class="whatsapp-result hidden">
                                        <div class="whatsapp-result-item">
                                            <label class="input-label" for="whatsapp-wa-me-link">Link `wa.me`</label>
                                            <div class="tool-output-row">
                                                <input type="text" id="whatsapp-wa-me-link" readonly>
                                                <button class="tool-output-btn" type="button"
                                                    onclick="copyToolOutput('whatsapp-wa-me-link', 'Link wa.me copiado.')">
                                                    Copiar
                                                </button>
                                            </div>
                                        </div>

                                        <div class="whatsapp-result-item">
                                            <label class="input-label" for="whatsapp-api-link">Link `api.whatsapp.com`</label>
                                            <div class="tool-output-row">
                                                <input type="text" id="whatsapp-api-link" readonly>
                                                <button class="tool-output-btn" type="button"
                                                    onclick="copyToolOutput('whatsapp-api-link', 'Link api.whatsapp.com copiado.')">
                                                    Copiar
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </article>
                            <% } %>

                            <% if (activeToolSlug === 'color-picker') { %>
                                <article class="tool-card tool-focus-card color-picker-card">
                                    <div class="tool-focus-hero">
                                        <div class="tool-card-icon color-picker-icon" aria-hidden="true">
                                            <svg viewBox="0 0 96 96" fill="none">
                                                <circle cx="30" cy="30" r="18" fill="#EF4444" />
                                                <circle cx="66" cy="30" r="18" fill="#F59E0B" />
                                                <circle cx="30" cy="66" r="18" fill="#10B981" />
                                                <circle cx="66" cy="66" r="18" fill="#3B82F6" />
                                                <circle cx="48" cy="48" r="10" fill="#FFFFFF" />
                                            </svg>
                                        </div>

                                        <div class="tool-focus-copy">
                                            <h3>Color Picker</h3>
                                            <p>Suba uma imagem e a ferramenta encontra 4 cores presentes nela. Depois, arraste os alvos circulares sobre a imagem para atualizar cada hexadecimal em tempo real.</p>
                                        </div>
                                    </div>

                                    <div class="tool-focus-actions">
                                        <input type="file" id="color-picker-upload" accept="image/*" hidden>
                                        <button class="btn-pill btn-pill-dark" type="button" onclick="triggerColorPickerUpload()">
                                            Selecionar imagem
                                        </button>
                                        <span class="tool-focus-hint">
                                            PNG, JPG ou WEBP. Os 4 alvos podem ser reposicionados manualmente.
                                        </span>
                                    </div>

                                    <div id="color-picker-status" class="tool-inline-status" aria-live="polite"></div>

                                    <div id="color-picker-empty" class="color-picker-empty" onclick="triggerColorPickerUpload()">
                                        <div class="color-picker-empty-icon" aria-hidden="true">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                                                <polyline points="17 8 12 3 7 8" />
                                                <line x1="12" y1="3" x2="12" y2="15" />
                                            </svg>
                                        </div>
                                        <strong>Suba uma imagem para extrair a paleta</strong>
                                        <p>A ferramenta detecta 4 cores e posiciona alvos móveis para você refinar cada amostra.</p>
                                    </div>

                                    <div id="color-picker-stage" class="color-picker-stage hidden">
                                        <div id="color-picker-image-shell" class="color-picker-image-shell">
                                            <img id="color-picker-image" alt="Imagem enviada para extrair cores">
                                            <div id="color-picker-markers" class="color-picker-markers"></div>
                                        </div>
                                    </div>

                                    <div id="color-picker-swatches" class="color-picker-swatches hidden"></div>
                                    <canvas id="color-picker-canvas" class="hidden"></canvas>
                                </article>
                            <% } %>

                            <% if (activeToolSlug === 'correcao-texto') { %>
                                <article class="tool-card tool-focus-card text-correction-card">
                                    <div class="tool-focus-hero">
                                        <div class="tool-card-icon text-correction-icon" aria-hidden="true">
                                            <svg viewBox="0 0 96 96" fill="none">
                                                <rect x="14" y="16" width="68" height="56" rx="16" fill="#EEF2FF" />
                                                <path d="M28 34h40" stroke="#111827" stroke-width="6" stroke-linecap="round" />
                                                <path d="M28 48h24" stroke="#6366F1" stroke-width="6" stroke-linecap="round" />
                                                <path d="m56 51 8 8 14-18" stroke="#10B981" stroke-width="6" stroke-linecap="round" stroke-linejoin="round" />
                                            </svg>
                                        </div>

                                        <div class="tool-focus-copy">
                                            <h3>Correção de Texto</h3>
                                            <p>Cole uma copy em português do Brasil para revisar ortografia, gramática e estilo com apoio do LanguageTool. Você pode aplicar sugestões individuais sem sair da tela.</p>
                                        </div>
                                    </div>

                                    <div class="tool-focus-form">
                                        <div class="input-group">
                                            <label class="input-label" for="text-correction-input">Texto para revisar</label>
                                            <textarea id="text-correction-input" rows="10"
                                                placeholder="Cole aqui a copy, legenda, roteiro ou mensagem que você quer corrigir."></textarea>
                                        </div>
                                    </div>

                                    <div class="tool-focus-actions">
                                        <button class="btn-pill btn-pill-dark" type="button" onclick="runTextCorrection()">
                                            Corrigir texto
                                        </button>
                                        <span class="tool-focus-hint">
                                            A análise busca inconsistências gramaticais e sugere correções rápidas.
                                        </span>
                                    </div>

                                    <div id="text-correction-status" class="tool-inline-status" aria-live="polite"></div>

                                    <div id="text-correction-summary" class="text-correction-summary hidden"></div>
                                    <div id="text-correction-results" class="text-correction-results hidden"></div>
                                </article>
                            <% } %>
                        </div>
                    <% } %>
                </div>
            </section>

        </div>
    </main>

    <div id="qr-modal-overlay" class="qr-modal-overlay hidden" aria-hidden="true">
        <div class="qr-modal" role="dialog" aria-modal="true" aria-labelledby="qr-modal-title">
            <div class="qr-modal-header">
                <div>
                    <h3 id="qr-modal-title">QR Code gerado</h3>
                    <p>Seu QR Code esta pronto para baixar.</p>
                </div>
                <button id="qr-modal-close" class="qr-modal-close" type="button">Fechar</button>
            </div>

            <div class="qr-preview-frame">
                <canvas id="qr-preview-canvas" class="qr-preview-canvas"></canvas>
            </div>

            <div class="qr-modal-actions">
                <button id="qr-download-png" class="btn-pill btn-pill-dark qr-download-btn" type="button">
                    Baixar PNG
                </button>
                <button id="qr-download-svg" class="btn-pill qr-download-btn qr-download-btn-secondary" type="button">
                    Baixar SVG
                </button>
            </div>
        </div>
    </div>

    <script src="/qr-code-generator.js"></script>
    <script>
        let currentDoctorId = null;
        let lastGeneratedDoctorId = null;
        let lastGeneratedCopy = '';
        let selectedTrend = null;
        const TRENDS_TOTAL = 12;
        let currentTrends = [];
        let trendSearchState = { query: '', matches: [], cursor: -1 };
        let activeQrCode = null;
        let activeQrSvg = '';
        let activeQrValue = '';
        let lastTextCorrectionMatches = [];
        const COLOR_PICKER_MARKER_COUNT = 4;
        const colorPickerState = {
            objectUrl: '',
            pixelData: null,
            pixelWidth: 0,
            pixelHeight: 0,
            markers: [],
            activeMarkerIndex: null
        };

        document.addEventListener('DOMContentLoaded', () => {
            const activePage = document.body.dataset.activePage || 'dashboard';
            const activeTool = document.body.dataset.activeTool || '';

            setGreeting();

            if (activePage === 'dashboard') {
                setupTrendControls();
                loadTrends();
                setupProductFeedbackPanel();

                setTimeout(() => {
                    document.querySelectorAll('.trend-card').forEach((card) => card.classList.add('visible'));
                }, 100);
            }

            if (activePage === 'planejamento') {
                hydratePlanningPrefill();
                loadDoctors();
            }

            if (activePage === 'ferramentas' && activeTool === 'gerador-qr') {
                setupQrTool();
            }

            if (activePage === 'ferramentas' && activeTool === 'gerador-whatsapp') {
                setupWhatsAppTool();
            }

            if (activePage === 'ferramentas' && activeTool === 'color-picker') {
                setupColorPickerTool();
            }

            if (activePage === 'ferramentas' && activeTool === 'correcao-texto') {
                setupTextCorrectionTool();
            }
        });

        function setGreeting() {
            const greetingEl = document.getElementById('greeting-main');
            if (!greetingEl) return;
            const h = new Date().getHours();
            const g = h < 12 ? 'Bom dia' : h < 18 ? 'Boa tarde' : 'Boa noite';
            greetingEl.innerText = g + ", <%= user.displayName.split(' ')[0] %>";
        }

        async function loadDoctors() {
            const select = document.getElementById('doctor-select');
            if (!select) return;

            try {
                const res = await fetch('/api/doctors');
                if (!res.ok) throw new Error('Falha ao carregar medicos');
                const data = await res.json();

                select.innerHTML = '<option value="" disabled selected>Selecione um médico...</option>';
                data.data.forEach(d => {
                    select.innerHTML += `<option value="${d.id}">${d.name}</option>`;
                });
                select.disabled = false;
            } catch (error) {
                console.error(error);
                select.innerHTML = '<option value="" disabled selected>Não foi possível carregar os médicos.</option>';
            }
        }

        function normalizeSearchText(text) {
            return String(text || '')
                .toLowerCase()
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '')
                .trim();
        }

        function resetTrendSearchState(clearInput = false) {
            trendSearchState = { query: '', matches: [], cursor: -1 };
            const statusEl = document.getElementById('trend-search-status');
            if (statusEl) statusEl.innerText = '';
            if (clearInput) {
                const input = document.getElementById('trend-search-input');
                if (input) input.value = '';
            }
            document.querySelectorAll('#trends-grid .trend-card').forEach((card) => {
                card.classList.remove('trend-card-match', 'trend-card-focus');
            });
        }

        function renderTrendPlaceholders(message) {
            const grid = document.getElementById('trends-grid');
            if (!grid) return;
            grid.innerHTML = '';
            for (let i = 0; i < TRENDS_TOTAL; i++) {
                const card = document.createElement('div');
                card.className = `trend-card visible stagger-${(i % TRENDS_TOTAL) + 1}`;
                const title = document.createElement('div');
                title.className = 'title';
                title.innerText = message;
                card.appendChild(title);
                grid.appendChild(card);
            }
        }

        function renderTrends(trends) {
            const grid = document.getElementById('trends-grid');
            if (!grid) return;
            grid.innerHTML = '';

            trends.slice(0, TRENDS_TOTAL).forEach((t, i) => {
                const card = document.createElement('div');
                card.className = `trend-card stagger-${(i % TRENDS_TOTAL) + 1}`;

                const top = document.createElement('div');
                const tags = document.createElement('div');
                tags.className = 'tags';
                tags.style.marginBottom = '8px';

                const tag = document.createElement('span');
                tag.style.fontSize = '0.65rem';
                tag.style.fontWeight = '700';
                tag.style.color = 'var(--primary)';
                tag.style.textTransform = 'uppercase';
                tag.style.letterSpacing = '0.05em';
                tag.innerText = `#${t.category || 'Tema'}`;

                const title = document.createElement('div');
                title.className = 'title';
                title.innerText = t.title || 'Tema indisponível no momento';

                tags.appendChild(tag);
                top.appendChild(tags);
                top.appendChild(title);

                const actions = document.createElement('div');
                actions.className = 'actions';

                const useBtn = document.createElement('button');
                useBtn.className = 'btn-trend btn-trend-primary';
                useBtn.type = 'button';
                useBtn.innerText = 'Usar tema';
                useBtn.addEventListener('click', (event) => {
                    event.stopPropagation();
                    useTrendTheme(t);
                });

                const link = document.createElement('a');
                link.className = 'btn-trend btn-trend-secondary';
                link.href = t.url || '#';
                link.target = '_blank';
                link.rel = 'noopener noreferrer';
                link.innerText = 'Saber mais';
                link.addEventListener('click', (event) => event.stopPropagation());

                actions.appendChild(useBtn);
                actions.appendChild(link);
                card.appendChild(top);
                card.appendChild(actions);
                grid.appendChild(card);

                setTimeout(() => card.classList.add('visible'), 50 + (i * 25));
            });

            const missing = Math.max(0, TRENDS_TOTAL - trends.length);
            for (let i = 0; i < missing; i++) {
                const card = document.createElement('div');
                card.className = `trend-card visible stagger-${(trends.length + i) % TRENDS_TOTAL + 1}`;
                const title = document.createElement('div');
                title.className = 'title';
                title.innerText = 'Trend indisponível no momento';
                card.appendChild(title);
                grid.appendChild(card);
            }
        }

        function searchTrends() {
            const input = document.getElementById('trend-search-input');
            const statusEl = document.getElementById('trend-search-status');
            if (!input || !statusEl) return;

            const queryRaw = input.value.trim();
            const normalizedQuery = normalizeSearchText(queryRaw);

            document.querySelectorAll('#trends-grid .trend-card').forEach((card) => {
                card.classList.remove('trend-card-match', 'trend-card-focus');
            });

            if (!normalizedQuery) {
                resetTrendSearchState(false);
                return;
            }

            if (normalizedQuery !== trendSearchState.query) {
                const matches = currentTrends.reduce((acc, trend, index) => {
                    const haystack = normalizeSearchText(`${trend.title || ''} ${trend.category || ''}`);
                    if (haystack.includes(normalizedQuery)) acc.push(index);
                    return acc;
                }, []);
                trendSearchState = { query: normalizedQuery, matches, cursor: -1 };
            }

            if (!trendSearchState.matches.length) {
                statusEl.innerText = 'Sem resultados';
                return;
            }

            const cards = Array.from(document.querySelectorAll('#trends-grid .trend-card'));
            trendSearchState.matches.forEach((index) => {
                if (cards[index]) cards[index].classList.add('trend-card-match');
            });

            trendSearchState.cursor = (trendSearchState.cursor + 1) % trendSearchState.matches.length;
            const targetIndex = trendSearchState.matches[trendSearchState.cursor];
            const targetCard = cards[targetIndex];
            if (targetCard) {
                targetCard.classList.add('trend-card-focus');
                targetCard.scrollIntoView({ behavior: 'smooth', block: 'center', inline: 'nearest' });
            }

            statusEl.innerText = `${trendSearchState.cursor + 1}/${trendSearchState.matches.length}`;
        }

        function setupTrendControls() {
            const searchInput = document.getElementById('trend-search-input');
            const searchBtn = document.getElementById('trend-search-btn');
            const refreshBtn = document.getElementById('trend-refresh-btn');

            if (searchBtn) searchBtn.addEventListener('click', searchTrends);
            if (searchInput) {
                searchInput.addEventListener('keydown', (event) => {
                    if (event.key === 'Enter') {
                        event.preventDefault();
                        searchTrends();
                    }
                });
                searchInput.addEventListener('input', () => {
                    if (!searchInput.value.trim()) {
                        resetTrendSearchState(false);
                    } else {
                        trendSearchState.cursor = -1;
                    }
                });
            }
            if (refreshBtn) refreshBtn.addEventListener('click', () => loadTrends({ forceRefresh: true }));
        }

        async function loadTrends({ forceRefresh = false } = {}) {
            const grid = document.getElementById('trends-grid');
            const statusEl = document.getElementById('trend-search-status');
            const refreshBtn = document.getElementById('trend-refresh-btn');
            if (!grid) return;

            resetTrendSearchState(false);
            renderTrendPlaceholders(forceRefresh ? 'Atualizando tendências...' : 'Carregando tendências...');
            if (refreshBtn) {
                refreshBtn.disabled = true;
                refreshBtn.innerText = 'Atualizando...';
            }

            try {
                const endpoint = forceRefresh ? '/api/trends?refresh=1' : '/api/trends';
                const res = await fetch(endpoint);
                if (!res.ok) throw new Error('Falha ao buscar tendências');
                const trends = await res.json();
                currentTrends = Array.isArray(trends) ? trends.slice(0, TRENDS_TOTAL) : [];
                renderTrends(currentTrends);
                if (statusEl) statusEl.innerText = `${currentTrends.length} trends`;
            } catch (e) {
                console.error(e);
                currentTrends = [];
                renderTrendPlaceholders('Falha ao carregar tendências.');
                if (statusEl) statusEl.innerText = 'Erro';
            } finally {
                if (refreshBtn) {
                    refreshBtn.disabled = false;
                    refreshBtn.innerText = 'Refresh';
                }
            }
        }

        function setToolInlineStatus(elementId, message, isError = false) {
            const statusEl = document.getElementById(elementId);
            if (!statusEl) return;
            statusEl.innerText = message || '';
            statusEl.classList.toggle('error', Boolean(isError && message));
            statusEl.classList.toggle('success', Boolean(!isError && message));
        }

        function setQrInlineStatus(message, isError = false) {
            setToolInlineStatus('qr-inline-status', message, isError);
        }

        function setupQrTool() {
            const overlay = document.getElementById('qr-modal-overlay');
            const closeBtn = document.getElementById('qr-modal-close');
            const downloadPngBtn = document.getElementById('qr-download-png');
            const downloadSvgBtn = document.getElementById('qr-download-svg');
            const input = document.getElementById('qr-input');

            if (closeBtn) closeBtn.addEventListener('click', closeQrModal);
            if (overlay) {
                overlay.addEventListener('click', (event) => {
                    if (event.target === overlay) closeQrModal();
                });
            }
            if (downloadPngBtn) downloadPngBtn.addEventListener('click', downloadQrPng);
            if (downloadSvgBtn) downloadSvgBtn.addEventListener('click', downloadQrSvg);
            if (input) {
                input.addEventListener('input', () => setQrInlineStatus(''));
                input.addEventListener('keydown', (event) => {
                    if ((event.ctrlKey || event.metaKey) && event.key === 'Enter') {
                        event.preventDefault();
                        openQrGeneratorModal();
                    }
                });
            }

            document.addEventListener('keydown', (event) => {
                if (event.key === 'Escape') closeQrModal();
            });
        }

        function setWhatsAppInlineStatus(message, isError = false) {
            setToolInlineStatus('whatsapp-inline-status', message, isError);
        }

        function setColorPickerStatus(message, isError = false) {
            setToolInlineStatus('color-picker-status', message, isError);
        }

        function setTextCorrectionStatus(message, isError = false) {
            setToolInlineStatus('text-correction-status', message, isError);
        }

        function setupWhatsAppTool() {
            const numberInput = document.getElementById('whatsapp-number');
            const messageInput = document.getElementById('whatsapp-message');

            if (numberInput) {
                numberInput.addEventListener('input', () => setWhatsAppInlineStatus(''));
                numberInput.addEventListener('keydown', (event) => {
                    if (event.key === 'Enter') {
                        event.preventDefault();
                        generateWhatsAppLinks();
                    }
                });
            }

            if (messageInput) {
                messageInput.addEventListener('input', () => setWhatsAppInlineStatus(''));
                messageInput.addEventListener('keydown', (event) => {
                    if ((event.ctrlKey || event.metaKey) && event.key === 'Enter') {
                        event.preventDefault();
                        generateWhatsAppLinks();
                    }
                });
            }
        }

        function setupColorPickerTool() {
            const uploadInput = document.getElementById('color-picker-upload');
            const imageShell = document.getElementById('color-picker-image-shell');

            if (uploadInput) {
                uploadInput.addEventListener('change', (event) => {
                    const file = event.target.files && event.target.files[0];
                    if (file) loadColorPickerImage(file);
                });
            }

            if (imageShell) {
                imageShell.addEventListener('pointerdown', handleColorPickerPointerDown);
            }

            document.addEventListener('pointermove', handleColorPickerPointerMove);
            document.addEventListener('pointerup', handleColorPickerPointerUp);
            document.addEventListener('pointercancel', handleColorPickerPointerUp);
        }

        function setupTextCorrectionTool() {
            const input = document.getElementById('text-correction-input');
            if (!input) return;

            input.addEventListener('input', () => {
                setTextCorrectionStatus('');
            });

            input.addEventListener('keydown', (event) => {
                if ((event.ctrlKey || event.metaKey) && event.key === 'Enter') {
                    event.preventDefault();
                    runTextCorrection();
                }
            });
        }

        function escapeHtml(value) {
            return String(value || '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function renderTextCorrectionSummary(matches) {
            const summary = document.getElementById('text-correction-summary');
            if (!summary) return;

            if (!matches.length) {
                summary.classList.add('hidden');
                summary.innerHTML = '';
                return;
            }

            const categories = new Set(matches.map((match) => match.rule?.category?.name).filter(Boolean));
            summary.innerHTML = `
                <strong>${matches.length} ponto(s) encontrado(s)</strong>
                <span>${categories.size ? `Categorias: ${Array.from(categories).join(', ')}` : 'Revise as sugestões abaixo.'}</span>
            `;
            summary.classList.remove('hidden');
        }

        function renderTextCorrectionResults(matches) {
            const container = document.getElementById('text-correction-results');
            if (!container) return;

            if (!matches.length) {
                container.classList.add('hidden');
                container.innerHTML = '';
                return;
            }

            container.innerHTML = matches.map((match, index) => {
                const suggestions = Array.isArray(match.replacements) ? match.replacements.slice(0, 4) : [];
                const excerpt = match.context && typeof match.context.text === 'string'
                    ? match.context.text
                    : '';
                const contextOffset = Number(match.context?.offset || 0);
                const errorLength = Number(match.length || 0);
                const markedExcerpt = excerpt
                    ? `${escapeHtml(excerpt.slice(0, contextOffset))}<mark>${escapeHtml(excerpt.slice(contextOffset, contextOffset + errorLength))}</mark>${escapeHtml(excerpt.slice(contextOffset + errorLength))}`
                    : escapeHtml(match.message || 'Sugestão encontrada.');

                return `
                    <article class="text-correction-item">
                        <div class="text-correction-item-top">
                            <span class="text-correction-category">${escapeHtml(match.rule?.category?.name || 'Revisão')}</span>
                            <span class="text-correction-rule">${escapeHtml(match.rule?.id || 'LanguageTool')}</span>
                        </div>
                        <p class="text-correction-message">${escapeHtml(match.message || 'Ajuste recomendado.')}</p>
                        <div class="text-correction-context">${markedExcerpt}</div>
                        <div class="text-correction-suggestions">
                            ${suggestions.length
                                ? suggestions.map((replacement) => `
                                    <button type="button" class="tool-output-btn text-correction-suggestion"
                                        onclick="applyTextCorrectionSuggestion(${index}, ${JSON.stringify(replacement.value)})">
                                        ${escapeHtml(replacement.value)}
                                    </button>
                                `).join('')
                                : '<span class="text-correction-no-suggestion">Sem sugestão automática para este ponto.</span>'
                            }
                        </div>
                    </article>
                `;
            }).join('');

            container.classList.remove('hidden');
        }

        async function runTextCorrection() {
            const input = document.getElementById('text-correction-input');
            const text = input ? input.value.trim() : '';

            if (!text) {
                setTextCorrectionStatus('Cole um texto para iniciar a revisão.', true);
                if (input) input.focus();
                return;
            }

            setTextCorrectionStatus('Analisando texto...');

            try {
                const response = await fetch('/api/tools/text-correction', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ text })
                });

                const data = await response.json();
                if (!response.ok) throw new Error(data.error || 'Falha ao revisar o texto.');

                const matches = Array.isArray(data.matches) ? data.matches : [];
                lastTextCorrectionMatches = matches;
                renderTextCorrectionSummary(matches);
                renderTextCorrectionResults(matches);

                if (!matches.length) {
                    setTextCorrectionStatus('Nenhum erro encontrado. Sua copy está redonda.');
                    return;
                }

                setTextCorrectionStatus(`${matches.length} sugestão(ões) pronta(s) para revisão.`);
            } catch (error) {
                console.error(error);
                lastTextCorrectionMatches = [];
                renderTextCorrectionSummary([]);
                renderTextCorrectionResults([]);
                setTextCorrectionStatus(error.message || 'Não foi possível revisar o texto.', true);
            }
        }

        function applyTextCorrectionSuggestion(matchIndex, replacement) {
            const input = document.getElementById('text-correction-input');
            const match = lastTextCorrectionMatches[matchIndex];
            if (!input || !match) return;

            const currentValue = input.value;
            const offset = Number(match.offset || 0);
            const length = Number(match.length || 0);
            input.value = `${currentValue.slice(0, offset)}${replacement}${currentValue.slice(offset + length)}`;
            setTextCorrectionStatus('Sugestão aplicada. Atualizando revisão...');
            runTextCorrection();
        }

        function triggerColorPickerUpload() {
            const input = document.getElementById('color-picker-upload');
            if (!input) return;
            input.value = '';
            input.click();
        }

        function loadColorPickerImage(file) {
            if (!file || !String(file.type || '').startsWith('image/')) {
                setColorPickerStatus('Envie um arquivo de imagem valido.', true);
                return;
            }

            const objectUrl = URL.createObjectURL(file);
            const image = new Image();

            image.onload = () => {
                try {
                    prepareColorPickerImage(image, objectUrl);
                } catch (error) {
                    console.error(error);
                    URL.revokeObjectURL(objectUrl);
                    setColorPickerStatus('Nao foi possivel processar a imagem enviada.', true);
                }
            };

            image.onerror = () => {
                URL.revokeObjectURL(objectUrl);
                setColorPickerStatus('Falha ao carregar a imagem. Tente outro arquivo.', true);
            };

            image.src = objectUrl;
        }

        function prepareColorPickerImage(image, objectUrl) {
            const canvas = document.getElementById('color-picker-canvas');
            const imageEl = document.getElementById('color-picker-image');
            const emptyState = document.getElementById('color-picker-empty');
            const stage = document.getElementById('color-picker-stage');
            if (!canvas || !imageEl || !emptyState || !stage) return;

            const ctx = canvas.getContext('2d', { willReadFrequently: true });
            const maxDimension = 1200;
            const scale = Math.min(1, maxDimension / Math.max(image.naturalWidth, image.naturalHeight));
            const width = Math.max(1, Math.round(image.naturalWidth * scale));
            const height = Math.max(1, Math.round(image.naturalHeight * scale));

            canvas.width = width;
            canvas.height = height;
            ctx.clearRect(0, 0, width, height);
            ctx.drawImage(image, 0, 0, width, height);

            const imageData = ctx.getImageData(0, 0, width, height);
            if (colorPickerState.objectUrl) URL.revokeObjectURL(colorPickerState.objectUrl);

            colorPickerState.objectUrl = objectUrl;
            colorPickerState.pixelData = imageData.data;
            colorPickerState.pixelWidth = width;
            colorPickerState.pixelHeight = height;
            colorPickerState.markers = buildInitialColorMarkers(imageData.data, width, height, COLOR_PICKER_MARKER_COUNT);
            colorPickerState.activeMarkerIndex = null;

            imageEl.onload = () => {
                renderColorPickerMarkers();
                renderColorPickerSwatches();
                setColorPickerStatus('4 cores detectadas. Arraste os alvos para ajustar a paleta.');
            };
            imageEl.src = objectUrl;

            emptyState.classList.add('hidden');
            stage.classList.remove('hidden');
        }

        function buildInitialColorMarkers(pixelData, width, height, count) {
            const pixels = collectColorSamplePixels(pixelData, width, height);
            if (!pixels.length) {
                return buildFallbackColorMarkers(count).map((marker) => refreshColorMarker(marker.x, marker.y));
            }

            const clusters = runColorKMeans(pixels, count);
            const markers = clusters.map((cluster) => buildMarkerFromCluster(cluster, width, height));

            while (markers.length < count) {
                markers.push(buildFallbackColorMarkers(count)[markers.length]);
            }

            return markers
                .slice(0, count)
                .sort((a, b) => (a.x - b.x) || (a.y - b.y))
                .map((marker) => refreshColorMarker(marker.x, marker.y));
        }

        function collectColorSamplePixels(pixelData, width, height) {
            const pixels = [];
            const step = Math.max(1, Math.floor(Math.max(width, height) / 80));

            for (let y = 0; y < height; y += step) {
                for (let x = 0; x < width; x += step) {
                    const index = ((y * width) + x) * 4;
                    const alpha = pixelData[index + 3];
                    if (alpha < 40) continue;

                    pixels.push({
                        r: pixelData[index],
                        g: pixelData[index + 1],
                        b: pixelData[index + 2],
                        x,
                        y
                    });
                }
            }

            return pixels;
        }

        function runColorKMeans(pixels, count) {
            const centroids = initializeColorCentroids(pixels, count);
            const assignments = new Array(pixels.length).fill(0);

            for (let iteration = 0; iteration < 7; iteration += 1) {
                const sums = Array.from({ length: count }, () => ({
                    r: 0,
                    g: 0,
                    b: 0,
                    count: 0
                }));

                for (let i = 0; i < pixels.length; i += 1) {
                    const pixel = pixels[i];
                    let nearestIndex = 0;
                    let nearestDistance = Number.POSITIVE_INFINITY;

                    for (let j = 0; j < centroids.length; j += 1) {
                        const distance = getColorDistanceSq(pixel, centroids[j]);
                        if (distance < nearestDistance) {
                            nearestDistance = distance;
                            nearestIndex = j;
                        }
                    }

                    assignments[i] = nearestIndex;
                    sums[nearestIndex].r += pixel.r;
                    sums[nearestIndex].g += pixel.g;
                    sums[nearestIndex].b += pixel.b;
                    sums[nearestIndex].count += 1;
                }

                let moved = false;

                for (let i = 0; i < centroids.length; i += 1) {
                    if (!sums[i].count) {
                        const fallback = pixels[Math.min(pixels.length - 1, i * Math.floor(pixels.length / Math.max(1, count)))];
                        centroids[i] = { r: fallback.r, g: fallback.g, b: fallback.b };
                        moved = true;
                        continue;
                    }

                    const nextCentroid = {
                        r: sums[i].r / sums[i].count,
                        g: sums[i].g / sums[i].count,
                        b: sums[i].b / sums[i].count
                    };

                    if (getColorDistanceSq(nextCentroid, centroids[i]) > 1) moved = true;
                    centroids[i] = nextCentroid;
                }

                if (!moved) break;
            }

            const clusters = Array.from({ length: count }, (_, index) => ({
                centroid: centroids[index],
                pixels: []
            }));

            for (let i = 0; i < pixels.length; i += 1) {
                clusters[assignments[i]].pixels.push(pixels[i]);
            }

            return clusters.filter((cluster) => cluster.pixels.length);
        }

        function initializeColorCentroids(pixels, count) {
            const average = pixels.reduce((accumulator, pixel) => {
                accumulator.r += pixel.r;
                accumulator.g += pixel.g;
                accumulator.b += pixel.b;
                return accumulator;
            }, { r: 0, g: 0, b: 0 });

            average.r /= pixels.length;
            average.g /= pixels.length;
            average.b /= pixels.length;

            const centroids = [];
            let firstPixel = pixels[0];
            let greatestDistance = -1;

            pixels.forEach((pixel) => {
                const distance = getColorDistanceSq(pixel, average);
                if (distance > greatestDistance) {
                    greatestDistance = distance;
                    firstPixel = pixel;
                }
            });

            centroids.push({ r: firstPixel.r, g: firstPixel.g, b: firstPixel.b });

            while (centroids.length < count) {
                let bestPixel = pixels[0];
                let bestDistance = -1;

                pixels.forEach((pixel) => {
                    let nearest = Number.POSITIVE_INFINITY;
                    centroids.forEach((centroid) => {
                        nearest = Math.min(nearest, getColorDistanceSq(pixel, centroid));
                    });

                    if (nearest > bestDistance) {
                        bestDistance = nearest;
                        bestPixel = pixel;
                    }
                });

                centroids.push({ r: bestPixel.r, g: bestPixel.g, b: bestPixel.b });
            }

            return centroids;
        }

        function getColorDistanceSq(a, b) {
            const dr = a.r - b.r;
            const dg = a.g - b.g;
            const db = a.b - b.b;
            return (dr * dr) + (dg * dg) + (db * db);
        }

        function buildMarkerFromCluster(cluster, width, height) {
            const averagePosition = cluster.pixels.reduce((accumulator, pixel) => {
                accumulator.x += pixel.x;
                accumulator.y += pixel.y;
                return accumulator;
            }, { x: 0, y: 0 });

            averagePosition.x /= cluster.pixels.length;
            averagePosition.y /= cluster.pixels.length;

            let bestPixel = cluster.pixels[0];
            let bestScore = Number.POSITIVE_INFINITY;

            cluster.pixels.forEach((pixel) => {
                const colorDistance = getColorDistanceSq(pixel, cluster.centroid);
                const positionDistance = ((pixel.x - averagePosition.x) ** 2) + ((pixel.y - averagePosition.y) ** 2);
                const score = colorDistance + (positionDistance * 0.08);

                if (score < bestScore) {
                    bestScore = score;
                    bestPixel = pixel;
                }
            });

            return {
                x: width <= 1 ? 0.5 : bestPixel.x / (width - 1),
                y: height <= 1 ? 0.5 : bestPixel.y / (height - 1)
            };
        }

        function buildFallbackColorMarkers(count) {
            return Array.from({ length: count }, (_, index) => ({
                x: (index + 1) / (count + 1),
                y: 0.45 + ((index % 2) * 0.12)
            }));
        }

        function refreshColorMarker(xRatio, yRatio) {
            const sampled = sampleColorAtRatios(xRatio, yRatio);
            return {
                x: clamp(xRatio, 0, 1),
                y: clamp(yRatio, 0, 1),
                r: sampled.r,
                g: sampled.g,
                b: sampled.b,
                hex: rgbToHex(sampled.r, sampled.g, sampled.b)
            };
        }

        function sampleColorAtRatios(xRatio, yRatio) {
            const width = colorPickerState.pixelWidth;
            const height = colorPickerState.pixelHeight;
            const pixelData = colorPickerState.pixelData;

            if (!pixelData || !width || !height) {
                return { r: 17, g: 24, b: 39 };
            }

            const centerX = Math.round(clamp(xRatio, 0, 1) * Math.max(0, width - 1));
            const centerY = Math.round(clamp(yRatio, 0, 1) * Math.max(0, height - 1));
            const radius = Math.max(1, Math.round(Math.min(width, height) / 180));
            let red = 0;
            let green = 0;
            let blue = 0;
            let count = 0;

            for (let y = centerY - radius; y <= centerY + radius; y += 1) {
                if (y < 0 || y >= height) continue;

                for (let x = centerX - radius; x <= centerX + radius; x += 1) {
                    if (x < 0 || x >= width) continue;

                    const index = ((y * width) + x) * 4;
                    if (pixelData[index + 3] < 40) continue;

                    red += pixelData[index];
                    green += pixelData[index + 1];
                    blue += pixelData[index + 2];
                    count += 1;
                }
            }

            if (!count) {
                const fallbackIndex = ((centerY * width) + centerX) * 4;
                return {
                    r: pixelData[fallbackIndex] || 17,
                    g: pixelData[fallbackIndex + 1] || 24,
                    b: pixelData[fallbackIndex + 2] || 39
                };
            }

            return {
                r: Math.round(red / count),
                g: Math.round(green / count),
                b: Math.round(blue / count)
            };
        }

        function rgbToHex(r, g, b) {
            return `#${[r, g, b].map((value) => value.toString(16).padStart(2, '0')).join('').toUpperCase()}`;
        }

        function clamp(value, min, max) {
            return Math.min(max, Math.max(min, value));
        }

        function renderColorPickerMarkers() {
            const markersContainer = document.getElementById('color-picker-markers');
            if (!markersContainer) return;

            markersContainer.innerHTML = '';

            colorPickerState.markers.forEach((marker, index) => {
                const button = document.createElement('button');
                button.type = 'button';
                button.className = 'color-picker-marker';
                button.dataset.index = String(index);
                button.title = marker.hex;
                button.setAttribute('aria-label', `Mover amostra da cor ${index + 1}`);
                button.style.left = `${marker.x * 100}%`;
                button.style.top = `${marker.y * 100}%`;
                button.style.backgroundColor = `rgba(${marker.r}, ${marker.g}, ${marker.b}, 0.24)`;
                button.innerHTML = '<span>+</span>';
                markersContainer.appendChild(button);
            });
        }

        function renderColorPickerSwatches() {
            const swatches = document.getElementById('color-picker-swatches');
            if (!swatches) return;

            if (!colorPickerState.markers.length) {
                swatches.classList.add('hidden');
                swatches.innerHTML = '';
                return;
            }

            swatches.innerHTML = colorPickerState.markers.map((marker, index) => `
                <div class="color-swatch-card">
                    <div class="color-swatch-preview" style="background:${marker.hex}"></div>
                    <div class="color-swatch-meta">
                        <span class="color-swatch-label">Cor ${index + 1}</span>
                        <button class="tool-output-btn color-swatch-copy" type="button"
                            onclick="copyColorHex(${index})">Copiar HEX</button>
                    </div>
                    <div class="color-swatch-hex">${marker.hex}</div>
                </div>
            `).join('');

            swatches.classList.remove('hidden');
        }

        function handleColorPickerPointerDown(event) {
            const marker = event.target.closest('.color-picker-marker');
            if (!marker) return;

            event.preventDefault();
            colorPickerState.activeMarkerIndex = Number(marker.dataset.index);
            updateColorPickerMarkerPosition(event.clientX, event.clientY);
        }

        function handleColorPickerPointerMove(event) {
            if (colorPickerState.activeMarkerIndex === null) return;
            event.preventDefault();
            updateColorPickerMarkerPosition(event.clientX, event.clientY);
        }

        function handleColorPickerPointerUp() {
            colorPickerState.activeMarkerIndex = null;
        }

        function updateColorPickerMarkerPosition(clientX, clientY) {
            const imageShell = document.getElementById('color-picker-image-shell');
            const markerIndex = colorPickerState.activeMarkerIndex;
            if (!imageShell || markerIndex === null) return;

            const rect = imageShell.getBoundingClientRect();
            if (!rect.width || !rect.height) return;

            const xRatio = clamp((clientX - rect.left) / rect.width, 0, 1);
            const yRatio = clamp((clientY - rect.top) / rect.height, 0, 1);
            colorPickerState.markers[markerIndex] = refreshColorMarker(xRatio, yRatio);

            renderColorPickerMarkers();
            renderColorPickerSwatches();
        }

        async function copyColorHex(index) {
            const marker = colorPickerState.markers[index];
            if (!marker) return;

            try {
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    await navigator.clipboard.writeText(marker.hex);
                } else {
                    throw new Error('Clipboard indisponivel');
                }

                setColorPickerStatus(`${marker.hex} copiado com sucesso.`);
            } catch (error) {
                console.error(error);
                setColorPickerStatus('Nao foi possivel copiar automaticamente. Copie manualmente o HEX.', true);
            }
        }

        function sanitizeWhatsAppNumber(value) {
            return String(value || '').replace(/\D/g, '');
        }

        function generateWhatsAppLinks() {
            const numberInput = document.getElementById('whatsapp-number');
            const messageInput = document.getElementById('whatsapp-message');
            const result = document.getElementById('whatsapp-result');
            const waMeInput = document.getElementById('whatsapp-wa-me-link');
            const apiInput = document.getElementById('whatsapp-api-link');

            const sanitizedNumber = sanitizeWhatsAppNumber(numberInput ? numberInput.value : '');
            const message = messageInput ? messageInput.value.trim() : '';

            if (!sanitizedNumber) {
                setWhatsAppInlineStatus('Digite um numero valido para gerar o link.', true);
                if (numberInput) numberInput.focus();
                if (result) result.classList.add('hidden');
                return;
            }

            const encodedMessage = encodeURIComponent(message);
            const waMeLink = `https://wa.me/${sanitizedNumber}${message ? `?text=${encodedMessage}` : ''}`;
            const apiLink = `https://api.whatsapp.com/send?phone=${sanitizedNumber}${message ? `&text=${encodedMessage}` : ''}`;

            if (waMeInput) waMeInput.value = waMeLink;
            if (apiInput) apiInput.value = apiLink;
            if (result) result.classList.remove('hidden');

            setWhatsAppInlineStatus('Links gerados com sucesso.');
        }

        async function copyToolOutput(elementId, successMessage) {
            const input = document.getElementById(elementId);
            if (!input || !input.value) return;

            try {
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    await navigator.clipboard.writeText(input.value);
                } else {
                    input.focus();
                    input.select();
                    document.execCommand('copy');
                }
                setWhatsAppInlineStatus(successMessage || 'Link copiado.');
            } catch (error) {
                console.error(error);
                setWhatsAppInlineStatus('Nao foi possivel copiar automaticamente. Copie manualmente.', true);
            }
        }

        function getQrPreviewRenderOptions(qrCode) {
            const previewBoxSize = window.innerWidth <= 640 ? 300 : 360;
            const logicalSize = Number(qrCode?.size || 0) + 8;
            const previewScale = logicalSize > 0
                ? Math.max(2, Math.floor(previewBoxSize / logicalSize))
                : 6;

            return { scale: previewScale };
        }

        function openQrGeneratorModal() {
            const input = document.getElementById('qr-input');
            const overlay = document.getElementById('qr-modal-overlay');
            const canvas = document.getElementById('qr-preview-canvas');
            const value = input ? input.value.trim() : '';

            if (!value) {
                setQrInlineStatus('Digite um texto ou link para gerar o QR Code.', true);
                if (input) input.focus();
                return;
            }

            try {
                if (!window.ResultQRCode || typeof window.ResultQRCode.create !== 'function') {
                    throw new Error('Motor do QR Code indisponivel no momento.');
                }

                activeQrCode = window.ResultQRCode.create(value);
                activeQrValue = value;
                activeQrSvg = activeQrCode.toSvgString({ scale: 12 });
                activeQrCode.renderToCanvas(canvas, getQrPreviewRenderOptions(activeQrCode));

                setQrInlineStatus('QR Code gerado com sucesso.');
                if (overlay) {
                    overlay.classList.remove('hidden');
                    overlay.setAttribute('aria-hidden', 'false');
                }
            } catch (error) {
                console.error(error);
                setQrInlineStatus(error.message || 'Nao foi possivel gerar o QR Code.', true);
            }
        }

        function closeQrModal() {
            const overlay = document.getElementById('qr-modal-overlay');
            if (!overlay) return;
            overlay.classList.add('hidden');
            overlay.setAttribute('aria-hidden', 'true');
        }

        function getQrDownloadName() {
            const baseName = activeQrValue
                .toLowerCase()
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '')
                .replace(/[^a-z0-9]+/g, '-')
                .replace(/(^-|-$)/g, '')
                .slice(0, 40);

            return baseName || 'qr-code';
        }

        function downloadBlobFile(blob, filename) {
            const fileUrl = URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = fileUrl;
            link.download = filename;
            document.body.appendChild(link);
            link.click();
            link.remove();
            URL.revokeObjectURL(fileUrl);
        }

        function downloadQrPng() {
            if (!activeQrCode) return;

            const canvas = document.createElement('canvas');
            activeQrCode.renderToCanvas(canvas, { scale: 24 });

            canvas.toBlob((blob) => {
                if (!blob) {
                    alert('Nao foi possivel exportar o PNG do QR Code.');
                    return;
                }
                downloadBlobFile(blob, `${getQrDownloadName()}.png`);
            }, 'image/png');
        }

        function downloadQrSvg() {
            if (!activeQrSvg) return;
            const blob = new Blob([activeQrSvg], { type: 'image/svg+xml;charset=utf-8' });
            downloadBlobFile(blob, `${getQrDownloadName()}.svg`);
        }

        function hydratePlanningPrefill() {
            const promptInput = document.getElementById('prompt-input');
            if (!promptInput) return;

            try {
                const rawValue = sessionStorage.getItem('resultpubli-planning-prefill');
                if (!rawValue) return;

                const prefill = JSON.parse(rawValue);
                sessionStorage.removeItem('resultpubli-planning-prefill');

                if (prefill && prefill.prompt && !promptInput.value.trim()) {
                    promptInput.value = prefill.prompt;
                }

                if (prefill && prefill.selectedTrend && prefill.selectedTrend.url) {
                    selectedTrend = {
                        title: prefill.selectedTrend.title || prefill.selectedTrend.url,
                        url: prefill.selectedTrend.url
                    };
                    updateSelectedTrendUI();
                }
            } catch (error) {
                console.error(error);
                sessionStorage.removeItem('resultpubli-planning-prefill');
            }
        }

        function updateSelectedTrendUI() {
            const wrapper = document.getElementById('selected-trend-context');
            const link = document.getElementById('selected-trend-link');
            if (!wrapper || !link) return;

            if (!selectedTrend || !selectedTrend.url) {
                wrapper.classList.add('hidden');
                link.href = '#';
                link.innerText = '';
                return;
            }

            link.href = selectedTrend.url;
            link.innerText = selectedTrend.title || selectedTrend.url;
            wrapper.classList.remove('hidden');
        }

        function clearSelectedTrend() {
            selectedTrend = null;
            updateSelectedTrendUI();
        }

        function useTrendTheme(trend) {
            const title = trend && trend.title ? trend.title : '';
            const url = trend && trend.url ? trend.url : '';
            const prompt = `Quero um carrossel detalhado sobre: ${title}`;

            try {
                sessionStorage.setItem('resultpubli-planning-prefill', JSON.stringify({
                    prompt,
                    selectedTrend: title && url ? { title, url } : null
                }));
            } catch (error) {
                console.error(error);
            }

            window.location.href = '/planejamento';
        }

        // Logic placeholder for actual production calls (already implemented in backend)
        async function generateCopy() {
            const docId = document.getElementById('doctor-select').value;
            const prompt = document.getElementById('prompt-input').value;
            if (!docId || !prompt) return alert('Selecione um médico e preencha o prompt.');

            document.getElementById('loader').style.display = 'block';
            document.getElementById('btn-generate').style.display = 'none';

            const res = await fetch('/api/orchestrate', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    doctorId: docId,
                    prompt,
                    trendUrl: selectedTrend?.url || '',
                    trendTitle: selectedTrend?.title || ''
                })
            });
            const data = await res.json();
            document.getElementById('loader').style.display = 'none';
            if (data.copy) {
                lastGeneratedDoctorId = docId;
                lastGeneratedCopy = data.copy;
                document.getElementById('generated-content').innerText = data.copy;
                document.getElementById('step-result').classList.remove('hidden');
                // hide feedback UI if previously opened
                const fp = document.getElementById('feedback-panel');
                if (fp) fp.classList.add('hidden');
            } else {
                lastGeneratedCopy = '';
                alert('Erro na geração.');
                document.getElementById('btn-generate').style.display = 'block';
            }
        }

        function resetPromptArea() {
            document.getElementById('step-result').classList.add('hidden');
            document.getElementById('btn-generate').style.display = 'block';
            document.getElementById('prompt-input').value = '';
            document.getElementById('generated-content').innerText = '';
            clearSelectedTrend();
            lastGeneratedDoctorId = null;
            lastGeneratedCopy = '';
            const promptInput = document.getElementById('prompt-input');
            if (promptInput) promptInput.focus();
        }

        document.getElementById('selected-trend-clear')?.addEventListener('click', clearSelectedTrend);

        function setupProductFeedbackPanel() {
            const openBtn = document.getElementById('open-product-feedback');
            const panel = document.getElementById('product-feedback-panel');
            const cancelBtn = document.getElementById('product-feedback-cancel');
            const sendBtn = document.getElementById('product-feedback-send');
            const ta = document.getElementById('product-feedback-text');
            const statusEl = document.getElementById('product-feedback-status');

            if (!openBtn || !panel || !cancelBtn || !sendBtn || !ta || !statusEl) return;

            openBtn.addEventListener('click', () => {
                panel.classList.toggle('hidden');
                if (!panel.classList.contains('hidden')) ta.focus();
            });

            cancelBtn.addEventListener('click', () => {
                panel.classList.add('hidden');
                ta.value = '';
                statusEl.innerText = '';
            });

            sendBtn.addEventListener('click', async () => {
                const text = ta.value.trim();
                if (!text) return alert('Escreva uma mensagem antes de enviar.');

                sendBtn.disabled = true;
                statusEl.innerText = 'Enviando...';

                try {
                    const resp = await fetch('/api/tool-feedback-email', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ message: text })
                    });
                    const data = await resp.json();

                    if (!resp.ok) throw new Error(data.error || 'Falha ao enviar.');

                    statusEl.innerText = 'Obrigado pelo feedback.';
                    ta.value = '';
                    setTimeout(() => {
                        panel.classList.add('hidden');
                        statusEl.innerText = '';
                    }, 1200);
                } catch (err) {
                    statusEl.innerText = err.message || 'Erro ao enviar.';
                } finally {
                    sendBtn.disabled = false;
                }
            });
        }

        function extractFilenameFromDisposition(disposition) {
            if (!disposition) return null;
            const utf8Match = disposition.match(/filename\*=UTF-8''([^;]+)/i);
            if (utf8Match && utf8Match[1]) return decodeURIComponent(utf8Match[1]);
            const plainMatch = disposition.match(/filename="?([^";]+)"?/i);
            return plainMatch ? plainMatch[1] : null;
        }

        async function downloadGeneratedDocx() {
            const copyText = (lastGeneratedCopy || document.getElementById('generated-content').innerText || '').trim();
            if (!copyText) return alert('Nenhum copy gerado para download.');

            const doctorSelect = document.getElementById('doctor-select');
            const doctorId = lastGeneratedDoctorId || (doctorSelect && doctorSelect.value ? doctorSelect.value : null);
            const btn = document.getElementById('btn-download');
            if (btn) btn.disabled = true;

            try {
                const resp = await fetch('/api/download-docx', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ doctorId, copyText })
                });

                if (!resp.ok) {
                    const errorBody = await resp.json().catch(() => ({}));
                    throw new Error(errorBody.error || 'Falha ao gerar arquivo .docx');
                }

                const blob = await resp.blob();
                const disposition = resp.headers.get('content-disposition');
                const filename = extractFilenameFromDisposition(disposition) || 'copy.docx';

                const fileUrl = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = fileUrl;
                a.download = filename;
                document.body.appendChild(a);
                a.click();
                a.remove();
                URL.revokeObjectURL(fileUrl);
            } catch (err) {
                console.error(err);
                alert(err.message || 'Erro ao baixar arquivo .docx');
            } finally {
                if (btn) btn.disabled = false;
            }
        }

        // File list visual logic
        document.getElementById('file-upload')?.addEventListener('change', function () {
            const list = document.getElementById('file-list');
            if (!list) return;
            list.innerHTML = '';
            Array.from(this.files).forEach(f => {
                const li = document.createElement('li');
                li.innerText = '📄 ' + f.name + ' (' + (f.size / 1024 / 1024).toFixed(2) + 'MB)';
                list.appendChild(li);
            });
        });

        async function submitOnboarding() {
            const name = document.getElementById('ob-name').value.trim();
            const specialty = document.getElementById('ob-specialty').value.trim();
            const csResponsible = document.getElementById('ob-cs').value;
            const briefing = document.getElementById('ob-briefing').value.trim();
            const fileInput = document.getElementById('file-upload');
            const btn = document.getElementById('ob-submit-btn');

            if (!name || !specialty) {
                return alert('Preencha pelo menos nome e especialidade antes de criar a estrutura.');
            }

            btn.innerText = 'Criando no Drive...';
            btn.disabled = true;

            const formData = new FormData();
            formData.append('name', name);
            formData.append('specialty', specialty);
            formData.append('cs_responsible', csResponsible);
            formData.append('briefing', briefing);

            Array.from(fileInput.files || []).forEach((file) => {
                formData.append('files', file);
            });

            try {
                const resp = await fetch('/api/onboard-doctor', {
                    method: 'POST',
                    body: formData
                });
                const data = await resp.json();

                if (!resp.ok) {
                    throw new Error(data.error || 'Falha ao criar a estrutura no Drive.');
                }

                alert('Estrutura criada com sucesso no Drive.');
                document.getElementById('ob-name').value = '';
                document.getElementById('ob-specialty').value = '';
                document.getElementById('ob-briefing').value = '';
                if (fileInput) fileInput.value = '';
                document.getElementById('file-list').innerHTML = '';
                await loadDoctors();
            } catch (error) {
                console.error(error);
                alert(error.message || 'Erro ao criar a estrutura no Drive.');
            } finally {
                btn.innerText = '🚀 Criar Estrutura no Drive';
                btn.disabled = false;
            }
        }

        /* Feedback Modal (Dark Theme) */
        (function insertNewContentModal() {
            if (document.getElementById('new-content-modal-overlay')) return;
            const html = `
<style>
  #new-content-modal-overlay { position: fixed; inset: 0; background: rgba(17,24,39,0.18); display: none; align-items: center; justify-content: center; z-index: 1190; }
  #new-content-modal { width:100%; max-width:640px; background:var(--bg-card); border-radius:14px; padding:24px; box-shadow:var(--shadow-float); color:var(--text-main); border:1px solid var(--border-soft); }
  #new-content-modal h3 { margin:0 0 8px 0; font-size:1.08rem; }
  #new-content-modal p { margin:0; color:var(--text-secondary); font-size:0.95rem; line-height:1.6; }
  .new-content-actions { display:flex; gap:10px; margin-top:18px; align-items:center; flex-wrap:wrap; }
  .new-content-btn-secondary { background:var(--bg-card); border:1px solid var(--border-soft); color:var(--text-secondary); padding:10px 14px; border-radius:10px; cursor:pointer; font-weight:600; }
  .new-content-btn-primary { background:var(--text-main); color:#fff; border:none; padding:10px 14px; border-radius:10px; cursor:pointer; font-weight:600; }
</style>
<div id="new-content-modal-overlay" aria-hidden="true">
  <div id="new-content-modal" role="dialog" aria-modal="true" aria-labelledby="new-content-modal-title">
    <h3 id="new-content-modal-title">Comecar um novo planejamento</h3>
    <p>Quer iniciar um novo planejamento agora? Se quiser, voce pode baixar o conteudo atual antes de limpar a tela. O medico e o atendimento selecionados vao continuar salvos.</p>
    <div class="new-content-actions">
      <button id="new-content-download" class="new-content-btn-secondary" type="button">Baixar conteudo atual</button>
      <button id="new-content-confirm" class="new-content-btn-primary" type="button">Criar novo</button>
      <button id="new-content-cancel" class="new-content-btn-secondary" type="button">Cancelar</button>
    </div>
  </div>
</div>`;
            const wrapper = document.createElement('div');
            wrapper.innerHTML = html;
            document.body.appendChild(wrapper);
        })();

        function openNewContentModal() {
            const overlay = document.getElementById('new-content-modal-overlay');
            if (!overlay) return;
            overlay.style.display = 'flex';
            overlay.setAttribute('aria-hidden', 'false');
        }

        function closeNewContentModal() {
            const overlay = document.getElementById('new-content-modal-overlay');
            if (!overlay) return;
            overlay.style.display = 'none';
            overlay.setAttribute('aria-hidden', 'true');
        }

        // Modal HTML (hidden by default)
        (function insertFeedbackModal() {
            if (document.getElementById('feedback-modal-overlay')) return;
            const html = `
<style>
  #feedback-modal-overlay { position: fixed; inset: 0; background: rgba(17,24,39,0.18); display: none; align-items: center; justify-content: center; z-index: 1200; }
  #feedback-modal { width:100%; max-width:720px; background:var(--bg-card); border-radius:14px; padding:20px; box-shadow:var(--shadow-float); color:var(--text-main); border:1px solid var(--border-soft); }
  #feedback-modal h3 { margin:0 0 8px 0; font-size:1.05rem; }
  #feedback-modal p { margin:0 0 12px 0; color:var(--text-secondary); font-size:0.9rem; }
  #feedback-modal textarea { width:100%; background:var(--bg-hover); border:1px solid var(--border-soft); color:var(--text-main); padding:12px; border-radius:10px; resize:vertical; min-height:120px; font-size:0.95rem; }
  .feedback-actions { display:flex; gap:10px; margin-top:12px; align-items:center; }
  .feedback-btn-cancel { background:var(--bg-card); border:1px solid var(--border-soft); color:var(--text-secondary); padding:8px 12px; border-radius:10px; cursor:pointer; }
  .feedback-btn-send { background:var(--text-main); color:#fff; border:none; padding:10px 14px; border-radius:10px; cursor:pointer; font-weight:600; }
  #feedback-modal .status { margin-left:8px; color:var(--text-secondary); font-size:0.9rem; display:none; }
</style>
<div id="feedback-modal-overlay" aria-hidden="true">
  <div id="feedback-modal" role="dialog" aria-modal="true" aria-labelledby="feedback-modal-title">
    <h3 id="feedback-modal-title">Enviar feedback</h3>
    <p>Descreva o que deve ser ajustado ou observado no copy.</p>
    <textarea id="feedback-modal-text" placeholder="Ex: reduzir o tom promocional; focar em benefícios clínicos..."></textarea>
    <div class="feedback-actions">
      <button id="feedback-modal-cancel" class="feedback-btn-cancel" type="button">Cancelar</button>
      <button id="feedback-modal-send" class="feedback-btn-send" type="button">Enviar feedback</button>
      <div id="feedback-modal-status" class="status">Enviando...</div>
    </div>
  </div>
</div>`;
            const wrapper = document.createElement('div');
            wrapper.innerHTML = html;
            document.body.appendChild(wrapper);
        })();

        // Client-side modal logic and submit
        function openFeedbackModal() {
            const overlay = document.getElementById('feedback-modal-overlay');
            if (!overlay) return; overlay.style.display = 'flex'; overlay.setAttribute('aria-hidden', 'false');
            document.getElementById('feedback-modal-text').focus();
        }
        function closeFeedbackModal() {
            const overlay = document.getElementById('feedback-modal-overlay');
            if (!overlay) return; overlay.style.display = 'none'; overlay.setAttribute('aria-hidden', 'true');
            const status = document.getElementById('feedback-modal-status'); if (status) { status.style.display = 'none'; status.innerText = ''; }
        }

        // Intercept 'Revisar' button clicks and open modal
        document.addEventListener('click', (ev) => {
            const el = ev.target.closest && ev.target.closest('button, a');
            if (!el) return;
            const isReviewBtn = el.id === 'btn-review' || (el.innerText && el.innerText.trim().toLowerCase().includes('revisar'));
            if (!isReviewBtn) return;
            ev.preventDefault(); ev.stopPropagation(); openFeedbackModal();
        });

        document.addEventListener('DOMContentLoaded', () => {
            const newContentBtn = document.getElementById('btn-new-content');
            const newContentOverlay = document.getElementById('new-content-modal-overlay');
            const newContentCancel = document.getElementById('new-content-cancel');
            const newContentDownload = document.getElementById('new-content-download');
            const newContentConfirm = document.getElementById('new-content-confirm');
            const btnCancel = document.getElementById('feedback-modal-cancel');
            const btnSend = document.getElementById('feedback-modal-send');
            const overlay = document.getElementById('feedback-modal-overlay');

            if (newContentBtn) newContentBtn.addEventListener('click', (e) => {
                e.preventDefault();
                openNewContentModal();
            });
            if (newContentCancel) newContentCancel.addEventListener('click', (e) => {
                e.preventDefault();
                closeNewContentModal();
            });
            if (newContentOverlay) newContentOverlay.addEventListener('click', (e) => {
                if (e.target === newContentOverlay) closeNewContentModal();
            });
            if (newContentDownload) newContentDownload.addEventListener('click', async (e) => {
                e.preventDefault();
                await downloadGeneratedDocx();
            });
            if (newContentConfirm) newContentConfirm.addEventListener('click', (e) => {
                e.preventDefault();
                closeNewContentModal();
                resetPromptArea();
            });
            if (btnCancel) btnCancel.addEventListener('click', (e) => { e.preventDefault(); closeFeedbackModal(); });
            if (overlay) overlay.addEventListener('click', (e) => { if (e.target === overlay) closeFeedbackModal(); });

            if (btnSend) {
                btnSend.addEventListener('click', async (e) => {
                    e.preventDefault();
                    const statusEl = document.getElementById('feedback-modal-status');
                    const ta = document.getElementById('feedback-modal-text');
                    const doctorSelect = document.getElementById('doctor-select');
                    const doctorId = doctorSelect && doctorSelect.value ? doctorSelect.value : null;
                    if (!doctorId) return alert('Selecione um médico antes de enviar feedback.');
                    const text = ta.value.trim(); if (!text) return alert('Digite o feedback antes de enviar.');

                    if (statusEl) { statusEl.style.display = 'inline-block'; statusEl.innerText = 'Enviando...'; }
                    btnSend.disabled = true;

                    try {
                        const resp = await fetch('/api/feedback', {
                            method: 'POST', headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ doctorId, feedbackText: text })
                        });
                        const data = await resp.json();
                        if (resp.ok) {
                            if (statusEl) { statusEl.innerText = 'Enviado ✓'; }
                            setTimeout(() => { ta.value = ''; closeFeedbackModal(); btnSend.disabled = false; }, 700);
                        } else {
                            const err = data && data.error ? data.error : 'Falha ao enviar';
                            if (statusEl) { statusEl.innerText = err; }
                            btnSend.disabled = false;
                        }
                    } catch (err) {
                        if (statusEl) statusEl.innerText = 'Erro de rede'; btnSend.disabled = false;
                    }
                });
            }
        });
    </script>
